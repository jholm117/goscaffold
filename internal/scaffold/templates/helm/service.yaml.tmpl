apiVersion: v1
kind: Service
metadata:
  name: {{"{{"}} include "{{.ProjectName}}.fullname" . {{"}}"}}
  labels:
    {{"{{"}}- include "{{.ProjectName}}.labels" . | nindent 4 {{"}}"}}
spec:
  ports:
    - name: http-metrics
      port: {{"{{"}} .Values.service.port {{"}}"}}
      targetPort: http-metrics
      protocol: TCP
  selector:
    {{"{{"}}- include "{{.ProjectName}}.selectorLabels" . | nindent 4 {{"}}"}}
