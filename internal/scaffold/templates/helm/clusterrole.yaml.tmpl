{{"{{"}}- if .Values.rbac.create -{{"}}"}}
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{"{{"}} include "{{.ProjectName}}.fullname" . {{"}}"}}
  labels:
    {{"{{"}}- include "{{.ProjectName}}.labels" . | nindent 4 {{"}}"}}
rules:
  - apiGroups: [""]
    resources: ["pods", "services", "configmaps"]
    verbs: ["get", "list", "watch"]
{{"{{"}}- end {{"}}"}}
